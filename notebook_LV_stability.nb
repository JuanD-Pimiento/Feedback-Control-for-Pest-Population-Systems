Cell[CellGroupData[{
Cell["An\[AAcute]lisis sistema LV modificado", "Title",
 CellChangeTimes->{{3.973695094630621*^9, 
  3.973695103637804*^9}},ExpressionUUID->"171b6638-9690-d34a-8d74-\
5fece5eca9dd"],

Cell[CellGroupData[{

Cell["Valores num\[EAcute]ricos de simulaci\[OAcute]n", "Section",
 CellChangeTimes->{{3.9777726607041245`*^9, 
  3.977772680230091*^9}},ExpressionUUID->"8cbb32be-2412-a240-ad79-\
0cf445d1f6a9"],

Cell[TextData[{
 "\[Alpha]=1.5318 igual que en el modelo de Chac\[OAcute]n\n\[Beta]=0.1\n\
\[Gamma]=0.3\n\[Epsilon]\[Gamma]=0.3\nCondiciones iniciales:\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["x", "1"], "(", "0", ")"}], "=", "35"}], TraditionalForm]],
  ExpressionUUID->"6fd3e0b1-2cf1-8245-8654-50b94e77dc35"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["x", "2"], "(", "0", ")"}], "=", "5"}], TraditionalForm]],
  ExpressionUUID->"6e16a4e1-bf5a-664c-ad83-d4224de123fe"],
 "\nLa poblaci\[OAcute]n de plaga en equilibrio va a ser la poblaci\[OAcute]n \
deseada, para que se linealice en torno a la respuesta deseada. Este valor se \
fija en el 70% de la poblaci\[OAcute]n de plaga antes de iniciar la aplicaci\
\[OAcute]n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", 
     RowBox[{"1", "e"}]], "=", 
    RowBox[{"0.7", 
     RowBox[{
      SubscriptBox["x", "1"], "(", "T", ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"2cfa5094-d328-a744-89b3-51ed29d3c3ac"]
}], "Text",
 CellChangeTimes->{{3.9777726894263287`*^9, 3.977772936694006*^9}, {
   3.9777730751395435`*^9, 3.977773185971012*^9}, {3.977773240665901*^9, 
