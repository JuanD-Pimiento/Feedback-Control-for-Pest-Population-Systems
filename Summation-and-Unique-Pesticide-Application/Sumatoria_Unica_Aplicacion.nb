Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"P7sumx1", "=", 
  RowBox[{"Plot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"t", "<=", "1"}], ",", 
        RowBox[{"xe", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f1", " ", "only", " ", "for", " ", "t"}], "\[LessEqual]", 
        "1"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"1", "<=", "t", "<=", "3.6"}], ",", 
        RowBox[{"X1e", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", "   ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f2", " ", "only", " ", "for", " ", "1"}], "<=", "t", "<=", 
        "3.6"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"3.6", "<=", "t", "<=", "4.6"}], ",", 
        RowBox[{"X1\[CapitalDelta]e", "[", "t", "]"}], ",", "Undefined"}], 
       "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"4.6", "<=", "t", "<=", 
          RowBox[{"(", 
           RowBox[{"T2", "+", "\[CapitalDelta]"}], ")"}]}], "/.", 
         RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ",", 
        RowBox[{"X1sume", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"T2", "+", "\[CapitalDelta]"}], "/.", 
           RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ")"}], "<=", "t", "<=", 
         RowBox[{"(", 
