  RowBox[{"(", 
   RowBox[{
    RowBox[{"-", "0.5199149296654824`"}], "+", 
    FractionBox["1", 
     RowBox[{"0.008602931767141168`", "\[VeryThinSpace]", "-", 
      RowBox[{"0.0067532248448744555`", " ", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "4.6`"}], "+", "t"}], ")"}], " ", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"-", "1.5318`"}], "-", 
           RowBox[{"0.01382653404749079`", " ", 
            RowBox[{"UnitStep", "[", 
             RowBox[{
              RowBox[{"-", "4.6`"}], "+", "t"}], "]"}]}]}], ")"}]}]]}]}]]}], 
   ")"}]}]], "Output",
