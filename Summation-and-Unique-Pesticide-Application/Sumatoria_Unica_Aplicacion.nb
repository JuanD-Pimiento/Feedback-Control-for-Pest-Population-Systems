Cell[CellGroupData[{

Cell["\<\
Soluci\[OAcute]n y simulaci\[OAcute]n del modelo sumatoria de aplicaciones de \
pesticida\
\>", "Title",
 CellChangeTimes->{{3.9759556925162296`*^9, 3.97595570692325*^9}, {
  3.979073150572214*^9, 
  3.9790731764870033`*^9}},ExpressionUUID->"1658a792-d68b-0a47-accb-\
4f154b7e260f"],

Cell[CellGroupData[{

Cell["Soluci\[OAcute]n de la derivada en los pulsos de aplicaci\[OAcute]n", \
"Section",
 CellChangeTimes->{{3.9759557249338264`*^9, 3.975955737040777*^9}, {
  3.9791496919307365`*^9, 
  3.979149700085621*^9}},ExpressionUUID->"e1171c27-0b71-1949-b676-\
0cb605584bf5"],

Cell[TextData[{
 "Para la soluci\[OAcute]n del modelo ampliado, se aplica la ecuaci\[OAcute]n \
de la se\[NTilde]al de control por re-alimentaci\[OAcute]n de estado ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"u", "[", "t", "]"}], "=", 
   RowBox[{"k", "*", 
    RowBox[{"x", "[", "t", "]"}]}]}]], "InlineCode",ExpressionUUID->
  "9ba4b51b-6e33-814c-823c-49281636da9b"],
 "\nCon esta soluci\[OAcute]n de ",
 Cell[BoxData[
  RowBox[{"u", "[", "t", "]"}]], "InlineCode",ExpressionUUID->
  "4e4d4a4d-84bc-0345-9d96-b932c43473bd"],
 "el modelo ampliado de Chac\[OAcute]n toma la forma de una Ecuaci\[OAcute]n \
Diferencial de Riccati."
}], "Text",
 CellChangeTimes->{{3.9759557555441303`*^9, 
  3.975955892584961*^9}},ExpressionUUID->"c32db1ea-a149-1c4c-99e6-\
6a3d74eac54b"],

Cell[TextData[{
 "Modelo ampliado:\n",
 Cell[BoxData[
  RowBox[{
   FractionBox[
    RowBox[{"dx", "[", "t", "]"}], "dt"], "=", 
   RowBox[{
    RowBox[{"a", "\[Times]", 
     RowBox[{"x", "[", "t", "]"}]}], "+", "b", "-", 
    RowBox[{"k", "\[Times]", 
     RowBox[{"[", 
      RowBox[{
       UnderoverscriptBox["\[Sum]", 
        RowBox[{"j", "=", "2"}], "m"], 
       RowBox[{
        SubscriptBox["p", "j"], "[", "t", "]"}]}], "]"}], "\[Times]", 
     SuperscriptBox[
      RowBox[{"x", "[", "t", "]"}], "2"]}]}]}]], "InlineCode",ExpressionUUID->
  "c5514e9d-fd4f-9946-9b48-006c40a1df52"],
 "\nForma de la ED de Riccati\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"dy", "[", "x", "]"}], "dx"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"A", "[", "x", "]"}], "\[Times]", 
      SuperscriptBox[
       RowBox[{"y", "[", "x", "]"}], "2"]}], "+", 
     RowBox[{
      RowBox[{"B", "[", "x", "]"}], "\[Times]", 
      RowBox[{"y", "[", "x", "]"}]}], "+", 
     RowBox[{"C", "[", "x", "]"}]}]}], TraditionalForm]],ExpressionUUID->
  "affd1322-8425-2f46-a0df-9372aec1d3df"],
 "\nPara solucionar la ED de Riccati, se puede tomar una soluci\[OAcute]n \
particular de ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"x", "'"}], "[", "t", "]"}], "=", " ", "0"}]], "InlineCode",
  ExpressionUUID->"594cd9a1-3f6d-6a48-b1f8-4b8caa726e97"],
 ", que en este caso se denominaran ",
 Cell[BoxData[
  SubscriptBox["y", 
   RowBox[{"1", ",", "2"}]]], "InlineCode",ExpressionUUID->
  "0d2c880c-03a2-6c45-855d-32f2d95b24cf"],
 " que corresponden a ",
 Cell[BoxData[
  SubscriptBox["x", 
   RowBox[{"1", ",", "2"}]]], "InlineCode",ExpressionUUID->
  "5768b5a5-5df5-3c48-aab0-f6052c6b2dfd"],
 ". Y partir de la soluci\[OAcute]n particular se generaliza una soluci\
\[OAcute]n de ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"x", "'"}], "[", "t", "]"}]], "InlineCode",ExpressionUUID->
  "63ca82a2-c473-8d49-b13d-fb1966f2a77a"],
 " donde:\n",
 Cell[BoxData[
  RowBox[{
   RowBox[{"x", "[", "t", "]"}], "=", 
   RowBox[{
    SubscriptBox["x", "1"], "+", 
    FractionBox["1", 
     RowBox[{"v", "[", "t", "]"}]]}]}]], "InlineCode",ExpressionUUID->
  "fe1cef14-4b5d-f54e-adac-1ac00e7882c8"]
}], "Text",
 CellChangeTimes->{{3.9759559123364773`*^9, 3.975956336603388*^9}, {
  3.979073202410454*^9, 
  3.979073231582508*^9}},ExpressionUUID->"8e4a75b6-6769-234f-9982-\
60b55a749966"],

Cell[TextData[{
 "Soluci\[OAcute]n de la funci\[OAcute]n V(t) para soluci\[OAcute]n de x\
\[CloseCurlyQuote][t] como ED de Riccati ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"dy", "/", "dx"}], "=", 
   RowBox[{
    RowBox[{"Ax", "^", "2"}], "+", "Bx", "+", "C"}]}]], "InlineCode",
  ExpressionUUID->"1448827e-0257-ce48-9144-e4943cacfcad"]
}], "Text",
