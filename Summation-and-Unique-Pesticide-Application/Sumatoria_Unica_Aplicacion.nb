 CellLabel->"In[87]:=",ExpressionUUID->"0c21d1da-31a3-9944-bd33-9cb24b07e086"],

Cell[BoxData[
 FractionBox[
  RowBox[{"a", "+", 
   SqrtBox[
    RowBox[{
     SuperscriptBox["a", "2"], "+", 
     RowBox[{"4", " ", "b", " ", "K"}]}]], "-", 
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"a", " ", 
      RowBox[{"(", 
       RowBox[{"t", "-", "Tj\[CapitalDelta]"}], ")"}]}]], " ", 
    RowBox[{"(", 
     RowBox[{"a", "+", 
      SqrtBox[
       RowBox[{
        SuperscriptBox["a", "2"], "+", 
        RowBox[{"4", " ", "b", " ", "K"}]}]], "-", 
      RowBox[{"2", " ", "K", " ", "xTj\[CapitalDelta]"}]}], ")"}]}]}], 
  RowBox[{"2", " ", "K"}]]], "Output",
 CellChangeTimes->{
  3.979077834139921*^9, 3.979081811609848*^9, {3.9790830030822697`*^9, 
   3.9790830318500614`*^9}, 3.979083193338949*^9, {3.979083372700552*^9, 
   3.9790833775603104`*^9}, 3.9791508566906796`*^9, 3.979151253040201*^9, 
   3.9792542068436794`*^9},
 CellLabel->"Out[87]=",ExpressionUUID->"c33e77fd-81f0-4b4c-a96a-3482204678b6"]
}, Open  ]],

Cell[TextData[{
 "En ambas definiciones de X (X1 y X2) se puede observar que la \
funci\[OAcute]n se vuelve independiente de ",
 Cell[BoxData[
 "j"], "InlineCode",ExpressionUUID->"71bf82c3-2755-c147-bbee-42078b411c96"],
 ", lo que implica que"
}], "Text",
 CellChangeTimes->{{3.9790814479028263`*^9, 
  3.979081496368023*^9}},ExpressionUUID->"89c84171-ff55-554b-92da-\
7bfc88fd4446"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Gr\[AAcute]ficas - Simulaci\[OAcute]n (Misma poblaci\[OAcute]n de referencia \
para todos los pulsos)\
\>", "Section",
 CellChangeTimes->{{3.975951498886612*^9, 3.975951509931631*^9}, {
  3.97907443801458*^9, 
  3.97907445710507*^9}},ExpressionUUID->"102454c4-3dd0-2f40-bd31-\
6cf0668ba3bb"],

Cell[TextData[{
 "En esta secci\[OAcute]n se simula considerando el mismo ",
 Cell[BoxData[
  SubscriptBox["x", "r"]], "InlineCode",ExpressionUUID->
  "16613d99-b544-e34b-afed-9e2d957743cd"],
 " para todos los pulsos ",
 Cell[BoxData[
 "j"], "InlineCode",ExpressionUUID->"0c807c2a-2a33-a34b-99a3-ceb86693b56f"],
 ", por lo que la ganancia k sigue siendo valida en esta secci\[OAcute]n."
}], "Text",
 CellChangeTimes->{{3.9790749207798767`*^9, 
  3.979075003578203*^9}},ExpressionUUID->"a928c016-4687-1a48-8210-\
494e2f4462ff"],

Cell[CellGroupData[{

Cell[BoxData["k"], "Input",
 CellChangeTimes->{3.979075004538292*^9},
 CellLabel->"In[88]:=",ExpressionUUID->"25b2d620-0b86-ae40-9073-86788a0ac03e"],

Cell[BoxData["0.013296919609893458`"], "Output",
 CellChangeTimes->{{3.9790750341114902`*^9, 3.9790750350546303`*^9}, 
   3.979081811609848*^9, 3.979083193385832*^9, 3.9791508567057858`*^9, 
   3.979254206906908*^9},
 CellLabel->"Out[88]=",ExpressionUUID->"b16bc574-e5d4-c249-95ec-d86187a3c81d"]
}, Open  ]],

Cell[TextData[{
 "As\[IAcute] mismo se toma como base el an\[AAcute]lisis realizado para el \
modelo de \[UAcute]nica aplicaci\[OAcute]n, ya que el modelo de la sumatoria \
es una generalizaci\[OAcute]n del modelo de \[UAcute]nica aplicaci\[OAcute]n.\
\nEl periodo de aplicaci\[OAcute]n ",
 Cell[BoxData[
  SubscriptBox["T", "j"]], "InlineCode",ExpressionUUID->
  "890b34d0-59bc-af4a-b3cf-526481335897"],
 " se fija en 1+\[CapitalDelta], y se realizara hasta la tercera aplicaci\
\[OAcute]n.\nNota: M\[AAcute]s adelante se define la variable ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["T", "4"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "45d9cd1b-f396-f545-a736-d7c0a1db84f1"],
 " solo para indicar el final de las aplicaciones, no implica una cuarta \
aplicaci\[OAcute]n."
}], "Text",
 CellChangeTimes->{{3.9790749207798767`*^9, 3.979075003578203*^9}, {
  3.9790750592685413`*^9, 3.9790751176530876`*^9}, {3.979075214446928*^9, 
  3.979075263022274*^9}, {3.979075328455824*^9, 3.979075333725218*^9}, {
  3.97907536634564*^9, 3.9790754172817*^9}, {3.979075492957369*^9, 
  3.979075540864134*^9}, {3.9791672885013523`*^9, 
  3.979167374134964*^9}},ExpressionUUID->"f3407f92-1533-e24d-b5df-\
916a8b218ad7"],

