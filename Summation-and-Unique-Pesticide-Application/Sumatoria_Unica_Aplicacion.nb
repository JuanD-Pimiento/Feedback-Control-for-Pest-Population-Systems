Cell[BoxData[
 FractionBox[
  RowBox[{"a", "+", 
   RowBox[{
    SqrtBox[
     RowBox[{
      SuperscriptBox["a", "2"], "+", 
      RowBox[{"4", " ", "b", " ", "K"}]}]], " ", 
    RowBox[{"(", 
     RowBox[{"1", "+", 
      FractionBox["2", 
       RowBox[{
        RowBox[{"-", "1"}], "+", 
