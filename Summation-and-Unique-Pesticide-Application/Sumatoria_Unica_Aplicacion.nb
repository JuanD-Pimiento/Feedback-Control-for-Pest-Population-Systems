Cell[CellGroupData[{

Cell["Definici\[OAcute]n de k a partir de linealizaci\[OAcute]n", \
"Subsubsection",
 CellChangeTimes->{{3.975965568888439*^9, 
  3.9759655792667007`*^9}},ExpressionUUID->"58d0125d-cb84-2e41-b04d-\
b9275379b68c"],

Cell[TextData[{
 "La linealizaci\[OAcute]n a trav\[EAcute]s de la matriz jacobiana (con \
respecto a las variables de estado) evaluada en los puntos de equilibrio da \
como resultado la matriz ",
 StyleBox["A ",
  FontWeight->"Bold"],
 "de la representaci\[OAcute]n en espacio de estado. La matriz ",
 StyleBox["B",
  FontWeight->"Bold"],
 " se obtiene a partir de la derivada parcial con respecto a la entrada. Es v\
\[AAcute]lido recalcar que aqu\[IAcute] no se aplica la definici\[OAcute]n de \
",
 Cell[BoxData[
  RowBox[{
   RowBox[{"u", "[", "t", "]"}], "=", 
   RowBox[{"k", "*", 
    SuperscriptBox[
     RowBox[{"x", "[", "t", "]"}], "2"]}]}]], "InlineCode",
  FontWeight->"Bold",ExpressionUUID->"ec7fc95c-4ded-8441-910d-d171a9d66cb5"],
 " para conservar la variable de control al momento de derivar.\n",
 Cell[BoxData[
  RowBox[{"A", " ", "=", 
   FractionBox[
    RowBox[{"-", "b"}], 
    SubscriptBox["x", "r"]]}]], "InlineCode",ExpressionUUID->
  "912607e6-b6d1-ea40-bc1e-97025cb4ab48"],
 "\n",
 Cell[BoxData[
  RowBox[{"B", " ", "=", 
   RowBox[{"-", 
    SubscriptBox["x", "r"]}]}]], "InlineCode",ExpressionUUID->
  "e61b947b-e035-0140-a1e0-9e5e9973924b"],
 "\nEn este caso se estableci\[OAcute] la poblaci\[OAcute]n de referencia ",
 Cell[BoxData[
  SubscriptBox["x", "r"]], "InlineCode",ExpressionUUID->
  "46fc5597-9e81-4345-aef3-3a126e4b33f2"],
 " c\[OAcute]mo el punto de equilibrio.\nTeniendo en cuenta que los \
auto-valores nuevos ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "N"], TraditionalForm]],ExpressionUUID->
  "d7c6623d-af9b-ae45-b3b4-549aae79320b"],
 " se obtienen c\[OAcute]mo:\n",
 Cell[BoxData[{
  RowBox[{
   RowBox[{"A", "-", 
    RowBox[{"B", "\[Times]", "k"}]}], "=", 
   SubscriptBox["\[Lambda]", "N"]}], "\[IndentingNewLine]", 
  RowBox[{"k", "=", 
   FractionBox[
    RowBox[{"A", "-", 
     SubscriptBox["\[Lambda]", "N"]}], "B"]}]}], "InlineCode",ExpressionUUID->
  "e35ee1e1-da88-1542-8f11-09b9df952b74"]
}], "Text",
 CellChangeTimes->{{3.9759662049208775`*^9, 3.9759662819912624`*^9}, {
  3.975966409905012*^9, 3.975966480517399*^9}, {3.975966520572485*^9, 
  3.9759665238545113`*^9}, {3.9759666436813564`*^9, 3.975966645961956*^9}, {
  3.975966677557102*^9, 
  3.9759669232354183`*^9}},ExpressionUUID->"39adf2fb-300f-8647-98d6-\
ecc0712ebdc3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"k", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "b"}], "-", 
     RowBox[{"\[Lambda]", " ", "xr"}]}], ")"}], "/", 
   RowBox[{"(", 
    RowBox[{"xr", "^", "2"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9759655878713017`*^9, 3.9759656343428097`*^9}, {
  3.975965884128681*^9, 3.9759658890057487`*^9}},
 CellLabel->"In[18]:=",ExpressionUUID->"c8e1ca5a-eeaf-874b-91c1-508bbb59ee1d"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   RowBox[{"-", "b"}], "-", 
   RowBox[{"xr", " ", "\[Lambda]"}]}], 
  SuperscriptBox["xr", "2"]]], "Output",
 CellChangeTimes->{3.9759656350265083`*^9, 3.9759658898367786`*^9, 
  3.9771742384999695`*^9, 3.977247989848133*^9, 3.977252951302248*^9, 
