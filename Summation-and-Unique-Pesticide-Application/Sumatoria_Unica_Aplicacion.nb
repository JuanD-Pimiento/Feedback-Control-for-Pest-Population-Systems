Cell[CellGroupData[{

Cell["Funci\[OAcute]n X, usando X1, en el rango [0,T3]", "Subsubsection",
 CellChangeTimes->{{3.9790836058508625`*^9, 3.979083607696003*^9}, {
  3.9790837731334553`*^9, 3.979083778535919*^9}, {3.9791618162812576`*^9, 
  3.979161841095974*^9}, {3.9791622421480007`*^9, 
