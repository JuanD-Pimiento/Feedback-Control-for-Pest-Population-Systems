Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"p2", "=", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"X1e", "[", "t", "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", "1", ",", "1.5"}], "}"}], ",", 
     RowBox[{"PlotTheme", "\[Rule]", "\"\<Scientific\>\""}], ",", 
     RowBox[{
     "PlotLabel", 
      "->", "\"\<Funci\[OAcute]n poblaci\[OAcute]n a partir de x'[t] = a*x[t] \
+ b - k*x[t\!\(\*SuperscriptBox[\(]\), \(2\)]\)\>\""}], ",", 
     RowBox[{"AxesLabel", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<Tiempo\>\"", ",", "\"\<Poblaci\[OAcute]n\>\""}], "}"}]}], 
     ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"{", 
       RowBox[{"X1e", "[", "t", "]"}], "}"}]}], ",", 
     RowBox[{"GridLines", "->", "Automatic"}]}], "]"}]}], "*)"}]], "Input",
