Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"uX1sum", "[", "t_", "]"}], "=", 
  RowBox[{
   RowBox[{"k", "*", " ", 
    RowBox[{"X1sume", "[", "t", "]"}]}], "//", "FullSimplify"}]}]], "Input",
