                  RowBox[{
                   SuperscriptBox["a", "2"], "+", 
                   RowBox[{"4", " ", "b", " ", "K"}]}]]}], ")"}], " ", 
               RowBox[{"UnitStep", "[", 
                RowBox[{"t", "-", "Tj"}], "]"}]}]}], ")"}]}]], " ", 
          RowBox[{"(", 
           RowBox[{"a", "-", 
            SqrtBox[
             RowBox[{
              SuperscriptBox["a", "2"], "+", 
              RowBox[{"4", " ", "b", " ", "K"}]}]], "-", 
            RowBox[{"2", " ", "K", " ", "xTj"}]}], ")"}]}], 
         RowBox[{"a", "+", 
          SqrtBox[
           RowBox[{
            SuperscriptBox["a", "2"], "+", 
            RowBox[{"4", " ", "b", " ", "K"}]}]], "-", 
          RowBox[{"2", " ", "K", " ", "xTj"}]}]]}]]}], ")"}]}]}], 
