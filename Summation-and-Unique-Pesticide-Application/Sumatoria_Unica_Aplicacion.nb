Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"p5x1", "=", 
  RowBox[{"Plot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"t", "<=", "1"}], ",", 
        RowBox[{"xe", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f1", " ", "only", " ", "for", " ", "t"}], "\[LessEqual]", 
        "1"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"1", "<=", "t", "<=", "3.6"}], ",", 
        RowBox[{"X1e", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", "   ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f2", " ", "only", " ", "for", " ", "1"}], "<=", "t", "<=", 
        "3.6"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"t", ">=", "3.6"}], ",", 
        RowBox[{"{", 
         RowBox[{"X1\[CapitalDelta]e", "[", "t", "]"}], "}"}], ",", 
        "Undefined"}], "]"}]}], "   ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"f3", " ", "only", " ", "for", " ", "t"}], "\[GreaterEqual]", 
       "3.6"}], "*)"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "4.6"}], "}"}], ",", 
    RowBox[{"PlotTheme", "\[Rule]", "\"\<Scientific\>\""}], ",", 
    RowBox[{
    "PlotLabel", 
     "->", "\"\<Funci\[OAcute]n resultante (usando \!\(\*SubscriptBox[\(x\), \
\(1\)]\)) para la poblaci\[OAcute]n x[t] para t > 0\>\""}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<Poblaci\[OAcute]n\>\"", ",", "None"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\"\<Tiempo\>\"", ",", "None"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"xe", "[", "t", "]"}], ",", 
       RowBox[{"X1e", "[", "t", "]"}], ",", 
       RowBox[{"X1\[CapitalDelta]e", "[", "t", "]"}]}], "}"}]}], ",", 
    RowBox[{"GridLines", "->", "Automatic"}], ",", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.975969960580002*^9, 3.9759700810563736`*^9}, 
