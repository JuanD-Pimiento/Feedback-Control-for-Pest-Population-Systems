Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"P8sumx2", "=", 
  RowBox[{"Plot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"t", "<=", "1"}], ",", 
        RowBox[{"xe", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f1", " ", "only", " ", "for", " ", "t"}], "\[LessEqual]", 
        "1"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"1", "<=", "t", "<=", "3.6"}], ",", 
        RowBox[{"X2e", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", "   ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f2", " ", "only", " ", "for", " ", "1"}], "<=", "t", "<=", 
        "3.6"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"3.6", "<=", "t", "<=", "4.6"}], ",", 
        RowBox[{"X2\[CapitalDelta]e", "[", "t", "]"}], ",", "Undefined"}], 
       "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"4.6", "<=", "t", "<=", 
          RowBox[{"(", 
           RowBox[{"T2", "+", "\[CapitalDelta]"}], ")"}]}], "/.", 
         RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ",", 
        RowBox[{"X2sume", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"T2", "+", "\[CapitalDelta]"}], "/.", 
           RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ")"}], "<=", "t", "<=", 
         RowBox[{"(", 
          RowBox[{"T3", "/.", 
           RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ")"}]}], ",", 
        RowBox[{"X2aftersumj2", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",",
       "   ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f3", " ", "only", " ", "for", " ", "t"}], "\[GreaterEqual]", 
        "3.6"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"T3", "/.", 
           RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ")"}], "<=", "t", "<=", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"T3", "+", "\[CapitalDelta]"}], "/.", 
           RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ")"}]}], ",", 
        RowBox[{"X2sumj3", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"t", ">=", 
          RowBox[{"(", 
           RowBox[{"T3", "+", "\[CapitalDelta]"}], ")"}]}], "/.", 
         RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ",", 
        RowBox[{"X2aftersumj3", "[", "t", "]"}], ",", "Undefined"}], "]"}]}], 
     "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", 
      RowBox[{"T4", "/.", 
       RowBox[{"\[CapitalDelta]", "->", "2.6"}]}]}], "}"}], ",", 
    RowBox[{"PlotTheme", "\[Rule]", "\"\<Scientific\>\""}], ",", 
    RowBox[{
    "PlotLabel", 
     "->", "\"\<Funci\[OAcute]n resultante (usando \!\(\*SubscriptBox[\(x\), \
\(2\)]\)) para la poblaci\[OAcute]n x[t] para t > 0\>\""}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<Poblaci\[OAcute]n\>\"", ",", "None"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\"\<Tiempo\>\"", ",", "None"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"xe", "[", "t", "]"}], ",", 
       RowBox[{"X2e", "[", "t", "]"}], ",", 
       RowBox[{"X2\[CapitalDelta]e", "[", "t", "]"}], ",", 
       RowBox[{"X2sume", "[", "t", "]"}], ",", 
       RowBox[{"X2aftersumj2", "[", "t", "]"}], ",", 
       RowBox[{"X2sumj3", "[", "t", "]"}], ",", 
       RowBox[{"X2aftersumj3", "[", "t", "]"}]}], "}"}]}], ",", 
    RowBox[{"GridLines", "->", "Automatic"}], ",", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9791623915517273`*^9, 3.9791624152850475`*^9}, {
