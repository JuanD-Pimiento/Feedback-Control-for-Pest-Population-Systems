Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"V2", "=", 
  RowBox[{
   RowBox[{"K", "/", 
    RowBox[{"(", 
     RowBox[{"a", "-", 
      RowBox[{"2", " ", "Y1", " ", "K"}]}], ")"}]}], "+", 
   RowBox[{"C2", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"2", " ", "Y1", " ", "K", "*", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"\[CapitalDelta]", "*", 
          RowBox[{"(", 
           RowBox[{"j", "-", "1"}], ")"}]}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"t", "-", "Tj"}], ")"}], "*", 
          RowBox[{"UnitStep", "[", 
           RowBox[{"t", "-", "Tj"}], "]"}]}]}], ")"}]}], "-", 
      RowBox[{"a", "*", "t"}]}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9759460131681185`*^9, 3.9759460624221077`*^9}, {
