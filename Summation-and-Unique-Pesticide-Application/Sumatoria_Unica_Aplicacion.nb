Cell[CellGroupData[{

Cell["Gr\[AAcute]fica desde 0 hasta 4 usando x2.", "Subsubsection",
 CellChangeTimes->{{3.9759699371342583`*^9, 3.975969943644184*^9}, {
  3.977613269184725*^9, 
  3.977613269317631*^9}},ExpressionUUID->"60fd2e28-a766-124a-830d-\
0d56ba0d1e67"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"p5x2", "=", 
  RowBox[{"Plot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"t", "<=", "1"}], ",", 
        RowBox[{"xe", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f1", " ", "only", " ", "for", " ", "t"}], "\[LessEqual]", 
        "1"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"1", "<=", "t", "<=", "3.6"}], ",", 
        RowBox[{"X2e", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", "   ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f2", " ", "only", " ", "for", " ", "1"}], "<=", "t", "<=", 
        "3.6"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"t", ">=", "3.6"}], ",", 
        RowBox[{"{", 
         RowBox[{"X2\[CapitalDelta]e", "[", "t", "]"}], "}"}], ",", 
        "Undefined"}], "]"}]}], "   ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"f3", " ", "only", " ", "for", " ", "t"}], "\[GreaterEqual]", 
       "3.6"}], "*)"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", "7"}], "}"}], ",", 
    RowBox[{"PlotTheme", "\[Rule]", "\"\<Scientific\>\""}], ",", 
    RowBox[{
    "PlotLabel", 
     "->", "\"\<Funci\[OAcute]n resultante (usando \!\(\*SubscriptBox[\(x\), \
\(2\)]\)) para la poblaci\[OAcute]n x[t] para t > 0\>\""}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<Poblaci\[OAcute]n\>\"", ",", "None"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\"\<Tiempo\>\"", ",", "None"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"xe", "[", "t", "]"}], ",", 
       RowBox[{"X2e", "[", "t", "]"}], ",", 
       RowBox[{"X2\[CapitalDelta]e", "[", "t", "]"}]}], "}"}]}], ",", 
    RowBox[{"GridLines", "->", "Automatic"}], ",", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]], "Input",
