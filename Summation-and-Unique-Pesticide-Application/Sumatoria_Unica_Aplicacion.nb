       RowBox[{"Tj", "->", "T2"}], ",", 
       RowBox[{"xTj", "->", 
        RowBox[{"xTj2", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}]}], "}"}]}], "/.", 
    RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], "//", 
   "FullSimplify"}]}]], "Input",
