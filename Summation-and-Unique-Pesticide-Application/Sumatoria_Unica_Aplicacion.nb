Notebook[{

Cell[CellGroupData[{
Cell["\<\
Soluci\[OAcute]n y simulaci\[OAcute]n del modelo de \[UAcute]nica aplicaci\
\[OAcute]n de pesticida\
\>", "Title",
 CellChangeTimes->{{3.9759556925162296`*^9, 3.97595570692325*^9}, {
  3.979073150572214*^9, 
  3.979073161263729*^9}},ExpressionUUID->"ee0fe56a-989e-6942-92ea-\
4ac1a4501808"],

Cell[CellGroupData[{

Cell["Soluci\[OAcute]n de la derivada", "Section",
 CellChangeTimes->{{3.9759557249338264`*^9, 
  3.975955737040777*^9}},ExpressionUUID->"e3fbfbf2-b93e-4841-8fe2-\
7e53cd83419d"],

Cell[TextData[{
 "Para la soluci\[OAcute]n del modelo ampliado, se aplica la ecuaci\[OAcute]n \
de la se\[NTilde]al de control por re-alimentaci\[OAcute]n de estado ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"u", "[", "t", "]"}], "=", 
   RowBox[{"k", "*", 
    RowBox[{"x", "[", "t", "]"}]}]}]], "InlineCode",ExpressionUUID->
  "19255bbd-4734-1443-bf07-d28bb61e3c17"],
 "\nCon esta soluci\[OAcute]n de ",
 Cell[BoxData[
  RowBox[{"u", "[", "t", "]"}]], "InlineCode",ExpressionUUID->
  "5810853a-a4b8-6c46-9940-34656e2d4c1b"],
 "el modelo ampliado de Chac\[OAcute]n toma la forma de una Ecuaci\[OAcute]n \
Diferencial de Riccati."
}], "Text",
 CellChangeTimes->{{3.9759557555441303`*^9, 
  3.975955892584961*^9}},ExpressionUUID->"384e8b5a-1511-8a4d-b3c9-\
bad0238aef51"],

Cell[TextData[{
 "Modelo ampliado:\n",
 Cell[BoxData[
  RowBox[{
   FractionBox[
    RowBox[{"dx", "[", "t", "]"}], "dt"], "=", 
   RowBox[{
    RowBox[{"a", "\[Times]", 
     RowBox[{"x", "[", "t", "]"}]}], "+", "b", "-", 
    RowBox[{"k", "\[Times]", 
     SuperscriptBox[
      RowBox[{"x", "[", "t", "]"}], "2"]}]}]}]], "InlineCode",ExpressionUUID->
  "886bee0c-f41f-204c-a6ee-7a0637e2ef77"],
 "\nForma de la ED de Riccati\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    FractionBox[
     RowBox[{"dy", "[", "x", "]"}], "dx"], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"A", "[", "x", "]"}], "\[Times]", 
      SuperscriptBox[
       RowBox[{"y", "[", "x", "]"}], "2"]}], "+", 
     RowBox[{
      RowBox[{"B", "[", "x", "]"}], "\[Times]", 
      RowBox[{"y", "[", "x", "]"}]}], "+", 
     RowBox[{"C", "[", "x", "]"}]}]}], TraditionalForm]],ExpressionUUID->
  "102b42fe-5fb7-7948-a78b-c8e243ee4249"],
 "\nPara solucionar la ED de Riccati, se puede tomar una soluci\[OAcute]n \
particular de ",
 Cell[BoxData[
  RowBox[{
   RowBox[{
    RowBox[{"x", "'"}], "[", "t", "]"}], "=", " ", "0"}]], "InlineCode",
  ExpressionUUID->"8db256a7-0616-b04b-8c56-44f8b3c423bb"],
 ", que en este caso se denominaran ",
 Cell[BoxData[
  SubscriptBox["y", 
   RowBox[{"1", ",", "2"}]]], "InlineCode",ExpressionUUID->
  "d36665bd-917c-684f-bae4-5961a269b55a"],
 " que corresponden a ",
 Cell[BoxData[
  SubscriptBox["x", 
   RowBox[{"1", ",", "2"}]]], "InlineCode",ExpressionUUID->
  "3582e430-c2ff-d242-83c1-b8631d27a27e"],
 ". Y partir de la soluci\[OAcute]n particular se generaliza una soluci\
\[OAcute]n de ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"x", "'"}], "[", "t", "]"}]], "InlineCode",ExpressionUUID->
  "52dbe557-a831-3e45-87c5-00058318e7cb"],
 " donde:\n",
 Cell[BoxData[
  RowBox[{
   RowBox[{"x", "[", "t", "]"}], "=", 
   RowBox[{
    SubscriptBox["x", "1"], "+", 
    FractionBox["1", 
     RowBox[{"v", "[", "t", "]"}]]}]}]], "InlineCode",ExpressionUUID->
  "2b90ef06-e27b-6a46-8345-606a4d1af8dd"]
}], "Text",
 CellChangeTimes->{{3.9759559123364773`*^9, 
  3.975956336603388*^9}},ExpressionUUID->"ffc76b11-33b4-974d-846f-\
400c2a114dd3"],

Cell[TextData[{
 "Soluci\[OAcute]n de la funci\[OAcute]n V(t) para soluci\[OAcute]n de x\
\[CloseCurlyQuote][t] como ED de Riccati ",
 Cell[BoxData[
  RowBox[{
   RowBox[{"dy", "/", "dx"}], "=", 
   RowBox[{
    RowBox[{"Ax", "^", "2"}], "+", "Bx", "+", "C"}]}]], "InlineCode",
  ExpressionUUID->"bb7e60a3-634c-634f-a16e-986b03c54f72"]
}], "Text",
 CellChangeTimes->{{3.9759555341340103`*^9, 
  3.975955605699745*^9}},ExpressionUUID->"9d121e6c-fab8-f94e-aeab-\
462c1d5227b0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"v", "=", 
  RowBox[{
   RowBox[{"k", "/", 
    RowBox[{"(", 
     RowBox[{"a", "-", 
      RowBox[{"2", " ", "y1", " ", "k"}]}], ")"}]}], "+", 
   RowBox[{"Ce", "*", 
    RowBox[{"Exp", "[", 
     RowBox[{
      RowBox[{"2", " ", "y1", " ", "k", " ", 
       RowBox[{"(", 
        RowBox[{"t", "-", "T"}], ")"}], "*", 
       RowBox[{"UnitStep", "[", 
        RowBox[{"t", "-", "T"}], "]"}]}], "-", 
      RowBox[{"a", "*", "t"}]}], "]"}]}]}]}]], "Input",
 CellChangeTimes->{{3.9759460131681185`*^9, 3.9759460624221077`*^9}, {
   3.975946122429874*^9, 3.975946129647676*^9}, 3.9773157420873146`*^9},
 CellLabel->"In[1]:=",ExpressionUUID->"8c5f73ea-ea62-8240-a3dc-d93027f3087c"],

Cell[BoxData[
 RowBox[{
  RowBox[{"Ce", " ", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "a"}], " ", "t"}], "+", 
     RowBox[{"2", " ", "k", " ", 
      RowBox[{"(", 
       RowBox[{"t", "-", "T"}], ")"}], " ", "y1", " ", 
      RowBox[{"UnitStep", "[", 
       RowBox[{"t", "-", "T"}], "]"}]}]}]]}], "+", 
  FractionBox["k", 
   RowBox[{"a", "-", 
    RowBox[{"2", " ", "k", " ", "y1"}]}]]}]], "Output",
 CellChangeTimes->{
  3.9759460640542936`*^9, 3.97594613157942*^9, {3.975946302532433*^9, 
   3.975946317117697*^9}, 3.9759466580135326`*^9, 3.97595260204043*^9, 
   3.975952863251831*^9, 3.975952942666628*^9, 3.975963832873087*^9, 
   3.9771742080609818`*^9, 3.9772479671526127`*^9, 3.9772529380141716`*^9, 
   3.9773160874845085`*^9, 3.977332824591551*^9, 3.9773462161252384`*^9, 
   3.977592678388626*^9, 3.9783699142436295`*^9, 3.9790731121023216`*^9, 
   3.9790817986326313`*^9, 3.979083172590433*^9, 3.9791508350821743`*^9, 
   3.9792541728271713`*^9},
 CellLabel->"Out[1]=",ExpressionUUID->"da46cb09-144a-4042-a4af-5103f4d80005"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"sol", "=", 
  RowBox[{"Solve", "[", 
   RowBox[{
    RowBox[{"y", "==", 
     RowBox[{"y1", "+", 
      RowBox[{"(", 
       RowBox[{"v", "^", 
        RowBox[{"-", "1"}]}], ")"}]}]}], ",", "Ce"}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9759460976772537`*^9, 3.9759461003191543`*^9}},
 CellLabel->"In[2]:=",ExpressionUUID->"9a19c311-c3c8-c641-b0c7-4d5ca94b8c62"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"{", 
   RowBox[{"Ce", "\[Rule]", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"a", " ", "t"}], "-", 
        RowBox[{"2", " ", "k", " ", 
         RowBox[{"(", 
          RowBox[{"t", "-", "T"}], ")"}], " ", "y1", " ", 
         RowBox[{"UnitStep", "[", 
          RowBox[{"t", "-", "T"}], "]"}]}]}]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "+", 
        RowBox[{"k", " ", "y"}], "+", 
        RowBox[{"k", " ", "y1"}]}], ")"}]}], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"y", "-", "y1"}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"-", "a"}], "+", 
        RowBox[{"2", " ", "k", " ", "y1"}]}], ")"}]}]]}], "}"}], 
  "}"}]], "Output",
 CellChangeTimes->{{3.975946094974735*^9, 3.97594610114192*^9}, 
   3.9759461348110843`*^9, 3.975946321193641*^9, 3.975946658093654*^9, 
   3.9759526021881475`*^9, 3.975952863387497*^9, 3.97595294281489*^9, 
   3.975963833201206*^9, 3.977174208654688*^9, 3.977247967717804*^9, 
   3.977252938384695*^9, 3.977316087928831*^9, 3.977332825032671*^9, 
   3.9773462165822277`*^9, 3.977592678771244*^9, 3.978369914810627*^9, 
   3.979073112576084*^9, 3.9790734055696125`*^9, 3.979081798695175*^9, 
   3.979083172651928*^9, 3.979150835458969*^9, 3.9792541732199135`*^9},
 CellLabel->"Out[2]=",ExpressionUUID->"6b60ba76-539e-404b-b84b-c9d318c56094"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"ce", "=", 
  RowBox[{"Ce", "/.", 
   RowBox[{"sol", "[", 
    RowBox[{"[", "1", "]"}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9759461492176743`*^9, 3.975946161404226*^9}},
 CellLabel->"In[3]:=",ExpressionUUID->"0026c43b-4c9f-9143-8b0f-e2d2af631383"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{
     RowBox[{"a", " ", "t"}], "-", 
     RowBox[{"2", " ", "k", " ", 
      RowBox[{"(", 
       RowBox[{"t", "-", "T"}], ")"}], " ", "y1", " ", 
      RowBox[{"UnitStep", "[", 
       RowBox[{"t", "-", "T"}], "]"}]}]}]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "a"}], "+", 
     RowBox[{"k", " ", "y"}], "+", 
     RowBox[{"k", " ", "y1"}]}], ")"}]}], 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"y", "-", "y1"}], ")"}], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "a"}], "+", 
     RowBox[{"2", " ", "k", " ", "y1"}]}], ")"}]}]]], "Output",
 CellChangeTimes->{3.9759461621825128`*^9, 3.97594632385368*^9, 
  3.975946658109644*^9, 3.9759526022211704`*^9, 3.975952863419975*^9, 
  3.9759529428310013`*^9, 3.9759638332169266`*^9, 3.97717420867033*^9, 
  3.9772479677341633`*^9, 3.977252938400469*^9, 3.9773160879610023`*^9, 
  3.97733282505357*^9, 3.977346216602768*^9, 3.977592678803831*^9, 
  3.978369914858532*^9, 3.979073112607933*^9, 3.979081798727211*^9, 
  3.979083172651928*^9, 3.979150835475277*^9, 3.979254173235632*^9},
 CellLabel->"Out[3]=",ExpressionUUID->"191201e2-a689-ca42-9282-6bf8eee486b5"]
}, Open  ]],

Cell[CellGroupData[{

Cell["\<\
Definici\[OAcute]n de soluciones y1(equivalente a x1), y2(equivalente a x2)\
\>", "Subsection",
 CellChangeTimes->{{3.975946207717596*^9, 3.975946216007059*^9}, {
  3.975946288587204*^9, 3.975946294008112*^9}, {3.9759556176507034`*^9, 
  3.97595563731592*^9}},ExpressionUUID->"bd4cb1ee-b7ef-cf46-8335-\
41113a676378"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"x1", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"a", "-", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"a", "^", "2"}], " ", "+", " ", 
       RowBox[{"(", 
        RowBox[{"4", " ", "k", " ", "b"}], ")"}]}], "]"}]}], ")"}], "/", 
   RowBox[{"(", 
    RowBox[{"2", "k"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.97594622299387*^9, 3.9759462372867565`*^9}, {
  3.9759462818835583`*^9, 3.9759462820408535`*^9}, {3.977346079316044*^9, 
  3.9773460795856056`*^9}},
 CellLabel->"In[4]:=",ExpressionUUID->"fb0ea494-988b-fa42-ba1c-f54d05c9a68a"],

Cell[BoxData[
 FractionBox[
  RowBox[{"a", "-", 
   SqrtBox[
    RowBox[{
     SuperscriptBox["a", "2"], "+", 
     RowBox[{"4", " ", "b", " ", "k"}]}]]}], 
  RowBox[{"2", " ", "k"}]]], "Output",
 CellChangeTimes->{3.9759462429528084`*^9, 3.9759462960623436`*^9, 
  3.975946326412641*^9, 3.975946658125688*^9, 3.9759526022211704`*^9, 
  3.975952863436636*^9, 3.9759529428310013`*^9, 3.9759638332169266`*^9, 
  3.9771742087025642`*^9, 3.977247967766283*^9, 3.977252938400469*^9, 
  3.9773160879930325`*^9, 3.977332825058878*^9, 3.977346216606001*^9, 
  3.977592678819763*^9, 3.97836991490818*^9, 3.979073112623575*^9, 
  3.979081798727211*^9, 3.979083172667553*^9, 3.9791508355063324`*^9, 
  3.979254173235632*^9},
 CellLabel->"Out[4]=",ExpressionUUID->"2d47cad2-c6d0-2e46-8f29-78619ee7e03c"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"x2", "=", 
  RowBox[{
   RowBox[{"(", 
    RowBox[{"a", "+", 
     RowBox[{"Sqrt", "[", 
      RowBox[{
       RowBox[{"a", "^", "2"}], " ", "+", " ", 
       RowBox[{"(", 
        RowBox[{"4", " ", "k", " ", "b"}], ")"}]}], "]"}]}], ")"}], "/", 
   RowBox[{"(", 
    RowBox[{"2", "k"}], ")"}]}]}]], "Input",
 CellChangeTimes->{{3.975946245824148*^9, 3.975946250641199*^9}, {
  3.975946283794489*^9, 3.9759462838750873`*^9}, {3.9773460823458023`*^9, 
  3.9773460828157845`*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"7d215e37-e61a-dc45-b565-ecd6d7756f1d"],

Cell[BoxData[
 FractionBox[
  RowBox[{"a", "+", 
   SqrtBox[
    RowBox[{
     SuperscriptBox["a", "2"], "+", 
     RowBox[{"4", " ", "b", " ", "k"}]}]]}], 
  RowBox[{"2", " ", "k"}]]], "Output",
 CellChangeTimes->{3.975946251555841*^9, 3.975946298165985*^9, 
  3.9759463286712227`*^9, 3.975946658141788*^9, 3.975952602253601*^9, 
  3.9759528634694138`*^9, 3.975952942864033*^9, 3.975963833232559*^9, 
  3.9771742087025642`*^9, 3.977247967797817*^9, 3.9772529384161816`*^9, 
  3.9773160880245266`*^9, 3.9773328250822563`*^9, 3.977346216613014*^9, 
  3.9775926788354034`*^9, 3.978369914925194*^9, 3.979073112623575*^9, 
  3.979081798727211*^9, 3.979083172667553*^9, 3.9791508355220833`*^9, 
  3.9792541732673874`*^9},
 CellLabel->"Out[5]=",ExpressionUUID->"2e7e11e0-2550-b546-9214-175202a8943e"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Despeje de la constante C1", "Subsection",
 CellChangeTimes->{
  3.9759461734108105`*^9, {3.975955647556759*^9, 3.975955668557438*^9}, {
   3.97595640392593*^9, 
   3.975956405019436*^9}},ExpressionUUID->"350e7cad-e0fa-1945-8767-\
459263fe4816"],

Cell[CellGroupData[{

Cell["Evaluado en T, usando y1 (a-...)", "Subsubsection",
 CellChangeTimes->{
  3.975956406720825*^9, {3.97734608842276*^9, 
   3.9773460886796017`*^9}},ExpressionUUID->"b1e42786-0670-1545-8407-\
0f53931d2573"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"cT1", "=", 
  RowBox[{
   RowBox[{"ce", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"t", "->", "T"}], ",", 
      RowBox[{"y", "->", "xT"}], ",", 
      RowBox[{"y1", "->", "x1"}]}], "}"}]}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.975946181478143*^9, 3.975946189439174*^9}, {
  3.9759462602693405`*^9, 3.975946276521087*^9}, {3.97594633191789*^9, 
  3.975946362410433*^9}},
 CellLabel->"In[6]:=",ExpressionUUID->"fdeb3e3e-244c-a44a-a2c9-14786aae4df3"],

Cell[BoxData[
 FractionBox[
  RowBox[{
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"a", " ", "T"}]], " ", "k", " ", 
   RowBox[{"(", 
    RowBox[{"a", "+", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["a", "2"], "+", 
       RowBox[{"4", " ", "b", " ", "k"}]}]], "-", 
     RowBox[{"2", " ", "k", " ", "xT"}]}], ")"}]}], 
  RowBox[{
   SqrtBox[
    RowBox[{
     SuperscriptBox["a", "2"], "+", 
     RowBox[{"4", " ", "b", " ", "k"}]}]], " ", 
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", "a"}], "+", 
     SqrtBox[
      RowBox[{
       SuperscriptBox["a", "2"], "+", 
       RowBox[{"4", " ", "b", " ", "k"}]}]], "+", 
     RowBox[{"2", " ", "k", " ", "xT"}]}], ")"}]}]]], "Output",
 CellChangeTimes->{{3.975946345688486*^9, 3.975946363871908*^9}, 
   3.9759466582227097`*^9, 3.975952602285846*^9, 3.975952863485466*^9, 
   3.97595294302729*^9, 3.975963833451206*^9, 3.9771742090768127`*^9, 
   3.977247968152687*^9, 3.977252938626154*^9, 3.977316088412674*^9, 
   3.9773328253188324`*^9, 3.977346216815922*^9, 3.977592679159504*^9, 
   3.9783699154828854`*^9, 3.979073112827959*^9, 3.9790817989625435`*^9, 
   3.9790831727943974`*^9, 3.9791508357101192`*^9, 3.9792541734929523`*^9},
 CellLabel->"Out[6]=",ExpressionUUID->"9d73b1b8-a6fa-f845-b8f3-0baf85662cf8"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"X1", "=", 
  RowBox[{
   RowBox[{
    RowBox[{"y1", "+", 
     RowBox[{"1", "/", "v"}]}], " ", "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Ce", "->", "cT1"}], ",", 
      RowBox[{"y1", "->", "x1"}]}], "}"}]}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.9759464381582594`*^9, 3.975946488369251*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"02fea29f-d61e-d148-b851-523d27cf7927"],

Cell[BoxData[
 RowBox[{
  FractionBox["1", "2"], " ", 
  RowBox[{"(", 
   RowBox[{
    FractionBox["a", "k"], "+", 
    RowBox[{
     SqrtBox[
      RowBox[{
       SuperscriptBox["a", "2"], "+", 
       RowBox[{"4", " ", "b", " ", "k"}]}]], " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"-", 
        FractionBox["1", "k"]}], "+", 
       FractionBox["2", 
        RowBox[{"k", "+", 
         FractionBox[
          RowBox[{
           SuperscriptBox["\[ExponentialE]", 
            RowBox[{"-", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{"(", 
                RowBox[{"t", "-", "T"}], ")"}], " ", 
               RowBox[{"(", 
                RowBox[{"a", "+", 
                 RowBox[{
