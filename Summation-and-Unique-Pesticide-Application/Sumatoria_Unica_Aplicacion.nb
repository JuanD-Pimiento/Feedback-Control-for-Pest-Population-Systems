        SuperscriptBox["a", "2"], "+", 
        RowBox[{"4", " ", "b", " ", "K"}]}]], "+", 
      RowBox[{"2", " ", "K", " ", "xTj"}]}], ")"}]}], 
   RowBox[{
    SqrtBox[
     RowBox[{
      SuperscriptBox["a", "2"], "+", 
      RowBox[{"4", " ", "b", " ", "K"}]}]], " ", 
    RowBox[{"(", 
     RowBox[{"a", "+", 
