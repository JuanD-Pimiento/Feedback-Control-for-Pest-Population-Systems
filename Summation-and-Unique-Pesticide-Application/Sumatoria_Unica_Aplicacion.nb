ce2454a5e46f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"P3sumx1", "=", 
  RowBox[{"Plot", "[", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"t", "<=", "1"}], ",", 
        RowBox[{"xe", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f1", " ", "only", " ", "for", " ", "t"}], "\[LessEqual]", 
        "1"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"1", "<=", "t", "<=", "3.6"}], ",", 
        RowBox[{"X1e", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", "   ", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"f2", " ", "only", " ", "for", " ", "1"}], "<=", "t", "<=", 
        "3.6"}], "*)"}], "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"3.6", "<=", "t", "<=", "4.6"}], ",", 
        RowBox[{"X1\[CapitalDelta]e", "[", "t", "]"}], ",", "Undefined"}], 
       "]"}], ",", "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"4.6", "<=", "t", "<=", 
          RowBox[{"(", 
           RowBox[{"T2", "+", "\[CapitalDelta]"}], ")"}]}], "/.", 
         RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ",", 
        RowBox[{"X1sume", "[", "t", "]"}], ",", "Undefined"}], "]"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"t", ">=", 
          RowBox[{"(", 
           RowBox[{"T2", "+", "\[CapitalDelta]"}], ")"}]}], "/.", 
         RowBox[{"\[CapitalDelta]", "->", "2.6"}]}], ",", 
        RowBox[{"X1aftersumj2", "[", "t", "]"}], ",", "Undefined"}], "]"}]}], 
     "   ", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"f3", " ", "only", " ", "for", " ", "t"}], "\[GreaterEqual]", 
       "3.6"}], "*)"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{"{", 
     RowBox[{"t", ",", "0", ",", 
      RowBox[{"T3", "/.", 
       RowBox[{"\[CapitalDelta]", "->", "2.6"}]}]}], "}"}], ",", 
    RowBox[{"PlotTheme", "\[Rule]", "\"\<Scientific\>\""}], ",", 
    RowBox[{
    "PlotLabel", 
     "->", "\"\<Funci\[OAcute]n resultante (usando \!\(\*SubscriptBox[\(x\), \
\(1\)]\)) para la poblaci\[OAcute]n x[t] para t > 0\>\""}], ",", 
    RowBox[{"Frame", "->", "True"}], ",", 
    RowBox[{"FrameLabel", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\"\<Poblaci\[OAcute]n\>\"", ",", "None"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\"\<Tiempo\>\"", ",", "None"}], "}"}]}], "}"}]}], ",", 
    RowBox[{"PlotLegends", "->", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"xe", "[", "t", "]"}], ",", 
       RowBox[{"X1e", "[", "t", "]"}], ",", 
       RowBox[{"X1\[CapitalDelta]e", "[", "t", "]"}], ",", 
       RowBox[{"X1sume", "[", "t", "]"}], ",", 
       RowBox[{"X1aftersumj2", "[", "t", "]"}]}], "}"}]}], ",", 
    RowBox[{"GridLines", "->", "Automatic"}], ",", 
    RowBox[{"PlotRange", "->", "All"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.9791622533458138`*^9, 3.9791623594668007`*^9}, {
